# Postgres (Neon). Use the pooled connection string here for the app at
# runtime — for running `prisma migrate`/`db push` locally, temporarily swap
# in the non-pooled ("_NON_POOLING"/"_UNPOOLED") connection string instead,
# since migrations can be unreliable through a pgbouncer-style pooler.
DATABASE_URL="postgresql://user:password@ep-example-123456.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Resend (magic link + transactional email)
RESEND_API_KEY=""
EMAIL_FROM="Bedlay Gardens <onboarding@resend.dev>"

# Anthropic (vaccination certificate extraction)
ANTHROPIC_API_KEY=""

# Stripe (deposits, balances, refunds)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Shared secret required in the Authorization header of the balance auto-charge cron route
CRON_SECRET=""

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Cloudflare R2 (file storage — vaccination certs, dog photos, agreements,
# pupdates are private; gallery/hero media is public)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PRIVATE_BUCKET="bedlay-gardens-private"
R2_PUBLIC_BUCKET="bedlay-gardens-public"
R2_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
